# Database
DATABASE_URL=

# Better Auth secret
BA_SECRET=

# OAuth: Google
# Create credentials at: https://console.cloud.google.com/apis/credentials
# App type: Web application
# Authorized redirect URI (Callback URL): ${DOMAIN}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# OAuth: GitHub
# Create OAuth App at: https://github.com/settings/developers (OAuth Apps)
# Homepage URL: ${DOMAIN}
# Authorization callback URL: ${DOMAIN}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# OAuth: Facebook
# Create an app at: https://developers.facebook.com/apps/
# Valid OAuth Redirect URIs: ${DOMAIN}/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
NEXT_PUBLIC_FACEBOOK_CLIENT_ID=

# OAuth: LinkedIn
# Create an app at: https://www.linkedin.com/developers/apps
# Authorized redirect URL: ${DOMAIN}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=

# OAuth: TikTok
# Create an app at: https://developers.tiktok.com/
# Authorized redirect URI: ${DOMAIN}/api/auth/callback/tiktok
# Scopes: user.info.basic (and user.info.email if approved)
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
NEXT_PUBLIC_TIKTOK_CLIENT_ID=

# Base URL for your app (used for redirectURIs and baseURL)
# Example for local dev:
DOMAIN=http://localhost:3000

# Optional public API base (if used by the client)
NEXT_PUBLIC_API_URL=

# Comma-separated list of user emails or IDs to be seeded as admins
ADMIN_USERS=